{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri-search/refs/heads/main/.schemas/schema-2.1.1.json",
  "identifier": "default",
  "description": "Default capabilities for Inkling",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "store:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" }
      ]
    },
    "opener:default",
    "opener:allow-open-url",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**/*.pdf" },
        { "path": "$HOME/**/*.docx" },
        { "path": "$HOME/**/*.pptx" }
      ]
    }
  ]
}
